# Copy this file to `.env` and fill in your key. Only the API key is required.

# ── Your provider API key ──────────────────────────────────────────────────
# (OPENAI_API_KEY also still works, for backward compatibility.)
LLM_API_KEY=your-api-key-here

# ── Provider endpoint (optional) ────────────────────────────────────────────
# Leave unset for OpenAI. Set this to any OpenAI-compatible endpoint to use
# another provider. Examples:
#   Google Gemini:  https://generativelanguage.googleapis.com/v1beta/openai/
#   OpenRouter:     https://openrouter.ai/api/v1
#   Anthropic:      https://api.anthropic.com/v1/      (OpenAI-compat endpoint)
#   Local (Ollama): http://localhost:11434/v1
# LLM_BASE_URL=

# ── Models ───────────────────────────────────────────────────────────────────
# Narrative is the per-turn storyteller; summary is the cheap model used for
# context trimming and the resume recap. Use whatever names your provider
# expects (e.g. gemini-2.0-flash, anthropic/claude-..., a local model name).
MODEL_NARRATIVE=gpt-5.4-nano
MODEL_SUMMARY=gpt-4o-mini

# ── Reasoning effort (optional) ───────────────────────────────────────────────
# Only applies to OpenAI reasoning models: low | medium | high.
# Set to empty (or "none") for providers/models that don't accept it,
# otherwise the request may be rejected.
LLM_REASONING_EFFORT=low

# Note: the cost figures in the session summary are calibrated to the default
# OpenAI models. With other providers/models they're rough; the token counts
# and latency are still accurate.
